{
	"compilerOptions": {
		"target": "ES2020",
		"lib": ["DOM", "ESNext"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"paths": {
			"native-i18n": ["../../src/index.ts"],
			"native-i18n/*": ["../../src/*"]
		},
		"jsx": "react-jsx",
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true
	},
	"include": ["src"]
}
