{
	"name": "native-i18n",
	"version": "0.0.1",
	"description": "Your translations are your types.",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/rezics/native-i18n.git"
	},
	"bugs": {
		"url": "https://github.com/rezics/native-i18n/issues"
	},
	"homepage": "https://github.com/rezics/native-i18n#readme",
	"type": "module",
	"packageManager": "yarn@4.12.0",
	"exports": {
		".": {
			"import": {
				"types": "./dist/index.d.mts",
				"import": "./dist/index.mjs"
			},
			"require": {
				"types": "./dist/index.d.cts",
				"require": "./dist/index.cjs"
			}
		},
		"./ast": {
			"import": {
				"types": "./dist/ast.d.mts",
				"import": "./dist/ast.mjs"
			},
			"require": {
				"types": "./dist/ast.d.cts",
				"require": "./dist/ast.cjs"
			}
		},
		"./react": {
			"import": {
				"types": "./dist/react/index.d.mts",
				"import": "./dist/react/index.mjs"
			},
			"require": {
				"types": "./dist/react/index.d.cts",
				"require": "./dist/react/index.cjs"
			}
		},
		"./react/server": {
			"import": {
				"types": "./dist/react/server.d.mts",
				"import": "./dist/react/server.mjs"
			},
			"require": {
				"types": "./dist/react/server.d.cts",
				"require": "./dist/react/server.cjs"
			}
		},
		"./react/client": {
			"import": {
				"types": "./dist/react/client.d.mts",
				"import": "./dist/react/client.mjs"
			},
			"require": {
				"types": "./dist/react/client.d.cts",
				"require": "./dist/react/client.cjs"
			}
		},
		"./next": {
			"import": {
				"types": "./dist/next/index.d.mts",
				"import": "./dist/next/index.mjs"
			},
			"require": {
				"types": "./dist/next/index.d.cts",
				"require": "./dist/next/index.cjs"
			}
		},
		"./next/client": {
			"import": {
				"types": "./dist/next/client.d.mts",
				"import": "./dist/next/client.mjs"
			},
			"require": {
				"types": "./dist/next/client.d.cts",
				"require": "./dist/next/client.cjs"
			}
		}
	},
	"workspaces": [
		"./examples/*"
	],
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"prepublishOnly": "yarn build",
		"test": "vitest run"
	},
	"devDependencies": {
		"@types/react": "^19.2.14",
		"next": "15.5.20",
		"prettier": "^3.7.4",
		"react": "^19.2.7",
		"react-dom": "^19.2.7",
		"tsdown": "^0.18.2",
		"typescript": "^5.9.3",
		"vitest": "^2.1.9"
	},
	"dependencies": {
		"@formatjs/intl-localematcher": "^0.8.2"
	},
	"peerDependencies": {
		"next": ">=15",
		"react": ">=18"
	},
	"peerDependenciesMeta": {
		"next": {
			"optional": true
		},
		"react": {
			"optional": true
		}
	}
}
